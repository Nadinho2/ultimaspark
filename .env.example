# Copy to .env.local — never commit real secrets.

# --- Clerk (https://dashboard.clerk.com) ---
#
# LOCAL (npm run dev on http://localhost:3000):
#   Use the **Development** instance keys: pk_test_... and sk_test_...
#   Production keys (pk_live_...) are locked to your production domain (e.g. ultimaspark.com)
#   and will error on localhost: "Production Keys are only allowed for domain ..."
#
# VERCEL PRODUCTION:
#   Use **Production** keys: pk_live_... and sk_live_... in Vercel → Environment Variables.
#
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Must match your Next.js routes (defaults below match this repo)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Resend (transactional email)
RESEND_API_KEY=
# New lesson video emails: unset or any value except "false" = email all enrolled learners for that course.
# Set to "false" to only email VIDEO_EMAIL_TEST_TO or the admin who added the video (legacy MVP mode).
# SEND_VIDEO_EMAILS_TO_ALL=false
# VIDEO_EMAIL_TEST_TO=you@example.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: required for admin course CRUD + course reads when using DB (Vercel production).
# Dashboard → Project Settings → API → service_role (never expose to the browser / NEXT_PUBLIC_*).
SUPABASE_SERVICE_ROLE_KEY=

